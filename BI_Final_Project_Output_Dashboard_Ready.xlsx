   "source": [
    "# STEP 5\n",
    "# mapping score to sentiment\n",
    "\n",
    "def map_sentiment(score):\n",
    "    if score in [1, 2]:\n",
    "        return \"Negative\"\n",
    "    elif score == 3:\n",
    "        return \"Neutral\"\n",
    "    else:\n",
    "        return \"Positive\"\n",
    "\n",
    "df['Sentiment'] = df['Score'].apply(map_sentiment)\n",
    "\n",
    "print(\"Sentiment distribution:\")\n",
    "print(df['Sentiment'].value_counts())\n",
    "df[['Score', 'Sentiment']].head()"
   ]
  },
  {
