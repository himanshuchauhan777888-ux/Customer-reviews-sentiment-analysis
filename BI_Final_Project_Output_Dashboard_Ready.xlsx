   "source": [
    "# STEP 22:\n",
    "illegal_char_pattern = re.compile(r'[\\x00-\\x08\\x0B-\\x0C\\x0E-\\x1F]')\n",
    "\n",
    "def clean_for_excel(value):\n",
    "    if isinstance(value, str):\n",
    "        value = illegal_char_pattern.sub('', value)\n",
    "        value = value.replace('\\r', ' ').replace('\\n', ' ').replace('\\t', ' ')\n",
    "        value = re.sub(r'\\s+', ' ', value).strip()\n",
    "    return value\n",
    "\n",
    "print(\"Excel cleaning function ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8ed5a758-9fb5-4a4c-8315-394d08df9111",
   "metadata": {},
   "source": [
    "### Step 23: Making excel safe copies\n",
    "Preparing data before saving file."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "a325eb84-e93f-477c-9e98-8ad6dfb77385",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Excel-safe copies created successfully\n"
     ]
    }
   ],
   "source": [
    "# STEP 23:\n",
    "df_excel = df.copy()\n",
    "results_excel = results.copy()\n",
    "\n",
    "for col in df_excel.columns:\n",
    "    df_excel[col] = df_excel[col].apply(clean_for_excel)\n",
    "\n",
    "for col in results_excel.columns:\n",
    "    results_excel[col] = results_excel[col].apply(clean_for_excel)\n",
    "\n",
    "print(\"Excel-safe copies created successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f6db8f25-ac80-4eb3-850d-0e46cee287ae",
   "metadata": {},
   "source": [
    "### Step 24: Saving first excel file\n",
    "Saving cleaned data and predictions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "e8e80f0e-75a2-433c-8aab-24dd504cbd3d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "New Excel file created successfully: BI_Final_Project_Output.xlsx\n"
     ]
    }
   ],
   "source": [
    "# STEP 24:\n",
    "\n",
    "# Confusion matrix as DataFrame\n",
    "cm_df = pd.DataFrame(\n",
    "    cm,\n",
    "    index=[\"Negative\", \"Neutral\", \"Positive\"],\n",
    "    columns=[\"Negative\", \"Neutral\", \"Positive\"]\n",
    ")\n",
    "\n",
    "# saving file as BI_Final_Project_Output.xlsx\n",
    "\n",
    "file_path = \"BI_Final_Project_Output.xlsx\"\n",
    "\n",
    "with pd.ExcelWriter(file_path, engine='openpyxl', mode='w') as writer:\n",
    "    df_excel.to_excel(writer, sheet_name=\"Cleaned_Data\", index=False)\n",
    "    results_excel.to_excel(writer, sheet_name=\"Predictions\", index=False)\n",
    "    cm_df.to_excel(writer, sheet_name=\"Confusion_Matrix\")\n",
    "\n",
    "print(\"New Excel file created successfully:\", file_path)"
   ]
  },
  {
