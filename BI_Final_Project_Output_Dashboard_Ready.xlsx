   "source": [
    "# STEP 18: \n",
    "\n",
    "result_columns = [\n",
    "    'Id',\n",
    "    'ProductId',\n",
    "    'Summary',\n",
    "    'Text',\n",
    "    'Clean_Text',\n",
    "    'Score',\n",
    "    'Score_Label',\n",
    "    'Sentiment',\n",
    "    'Review_Date',\n",
    "    'Review_DayName',\n",
    "    'Is_Weekend',\n",
    "    'Review_Word_Count',\n",
    "    'Review_Char_Count',\n",
    "    'Text_Length_Group',\n",
    "    'HelpfulnessNumerator',\n",
    "    'HelpfulnessDenominator',\n",
    "    'Helpfulness_Ratio',\n",
    "    'Has_Helpful_Votes',\n",
    "    'Short_Review'\n",
    "]\n",
    "\n",
    "results = df.loc[X_test.index, result_columns].copy()\n",
    "results = results.reset_index(drop=True)\n",
    "\n",
    "results.rename(columns={'Sentiment': 'Actual_Sentiment'}, inplace=True)\n",
    "results['Predicted_Sentiment'] = y_pred\n",
    "\n",
    "results['Review_Status'] = np.where(\n",
    "    results['Actual_Sentiment'] == results['Predicted_Sentiment'],\n",
    "    'Correct',\n",
    "    'Incorrect'\n",
    ")\n",
    "\n",
    "results['Prediction_Flag'] = np.where(\n",
    "    results['Actual_Sentiment'] == results['Predicted_Sentiment'],\n",
    "    1,\n",
    "    0\n",
    ")\n",
    "\n",
    "print(\"Results table created successfully\")\n",
    "results.head()"
   ]
  },
