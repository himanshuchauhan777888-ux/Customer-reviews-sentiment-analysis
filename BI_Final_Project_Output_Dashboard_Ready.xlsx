   "source": [
    "# STEP 8\n",
    "# applying text cleaning\n",
    "\n",
    "df['Clean_Text'] = df['Text'].apply(clean_text)\n",
    "print(\"Sample cleaned text:\")\n",
    "df[['Text', 'Clean_Text']].head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b760a736-d05f-4f68-af17-725741c445a1",
   "metadata": {},
   "source": [
    "### Step 9: Removing empty cleaned text\n",
    "Here we are removing rows where cleaned text became empty after preprocessing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "a9df7030-8f5a-4d64-af3d-d5d7ca4002c6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shape after removing empty cleaned text: (99999, 15)\n"
     ]
    }
   ],
   "source": [
    "# STEP 9\n",
    "# removing empty cleaned text\n",
    "\n",
    "df = df[df['Clean_Text'].str.strip() != \"\"].copy()\n",
    "print(\"Shape after removing empty cleaned text:\", df.shape)"
   ]
  },
