   "source": [
    "### Step 6: Reducing text length\n",
    "Shortening the review text so processing becomes faster."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "34256a5b-7d77-406e-88e2-2bf0be2a5185",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Text length reduced successfully\n"
     ]
    }
   ],
   "source": [
    "# STEP 6\n",
    "# reducing text length\n",
    "df['Text'] = df['Text'].apply(lambda x: str(x)[:500])\n",
    "df['Summary'] = df['Summary'].apply(lambda x: str(x)[:200])\n",
    "\n",
    "print(\"Text length reduced successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a093c33e-b56d-4ad9-aa06-9d4ea8389074",
   "metadata": {},
   "source": [
    "### Step 7: Creating text cleaning function\n",
    "Here we are defining a function to clean text by removing unwanted elements."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "f60a9411-fe12-478b-88b2-f9241baba90a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Text preprocessing function is ready\n"
     ]
    }
   ],
   "source": [
    "# STEP 7\n",
    "# preparing stopwords and lemmatizer\n",
    "\n",
    "stop_words = set(stopwords.words('english'))\n",
    "lemmatizer = WordNetLemmatizer()\n",
    "\n",
    "# defining cleaning function\n",
    "def clean_text(text):\n",
    "    text = str(text).lower()\n",
    "    text = re.sub(r'<.*?>', ' ', text)\n",
    "    text = re.sub(r'http\\S+|www\\S+', ' ', text)\n",
    "    text = re.sub(r'\\d+', ' ', text)\n",
    "    text = text.translate(str.maketrans('', '', string.punctuation))\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "\n",
    "    tokens = text.split()\n",
    "\n",
    "    cleaned_tokens = []\n",
    "    for word in tokens:\n",
    "        if word not in stop_words and len(word) > 2:\n",
    "            cleaned_tokens.append(lemmatizer.lemmatize(word))\n",
    "\n",
    "    return \" \".join(cleaned_tokens)\n",
    "\n",
    "print(\"Text preprocessing function is ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "95b3ea4b-ead1-4616-b38b-83e296407fbd",
